---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

/**
 * BaseLayout — global shell with per-page SEO + Open Graph support.
 * Set `overHero` on pages whose first element is a full-bleed hero so the
 * nav starts transparent.
 */
interface Props {
  title: string;
  description: string;
  image?: string;
  noindex?: boolean;
  overHero?: boolean;
}

const {
  title,
  description,
  image = "/images/atmosphere/hero-atmosphere.svg",
  noindex = false,
  overHero = false,
} = Astro.props;

const siteName = "Renovation Consulting Co.";
const fullTitle = title.includes(siteName) ? title : `${title} — ${siteName}`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- JS flag: animation "start hidden" states only apply when JS is live,
         so content can never be stranded invisible if a script fails. -->
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta name="theme-color" content="#FBF7F2" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300..600&family=Instrument+Sans:wght@400..600&display=swap"
    />
  </head>

  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Nav overHero={overHero} />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      // --- Image loading: fade in on load, fall back to gradient on error ---
      // load/error don't bubble, so listen in the capture phase.
      const markImg = (img: HTMLImageElement) => {
        if (img.dataset.bound) return;
        img.dataset.bound = "1";
        if (img.complete) {
          img.naturalWidth > 0
            ? img.classList.add("is-loaded")
            : img.classList.add("is-failed");
        }
      };
      document.querySelectorAll<HTMLImageElement>("img[data-img]").forEach(markImg);
      document.addEventListener(
        "load",
        (e) => {
          const t = e.target as HTMLElement;
          if (t instanceof HTMLImageElement && t.dataset.img !== undefined)
            t.classList.add("is-loaded");
        },
        true
      );
      document.addEventListener(
        "error",
        (e) => {
          const t = e.target as HTMLElement;
          if (t instanceof HTMLImageElement && t.dataset.img !== undefined)
            t.classList.add("is-failed");
        },
        true
      );

      const prefersReduced = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;

      // --- Scroll reveal (all variants share the is-visible toggle) ---
      const revealSel =
        "[data-reveal], [data-reveal-clip], [data-reveal-group], .reveal-lines";
      const items = document.querySelectorAll<HTMLElement>(revealSel);

      if (prefersReduced || !("IntersectionObserver" in window)) {
        items.forEach((el) => el.classList.add("is-visible"));
      } else {
        const observer = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                obs.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: "0px 0px -8% 0px" }
        );
        items.forEach((el) => observer.observe(el));
      }

      // --- Gentle parallax for [data-parallax] images ---
      if (!prefersReduced) {
        const layers = Array.from(
          document.querySelectorAll<HTMLElement>("[data-parallax]")
        );
        if (layers.length) {
          let ticking = false;
          const update = () => {
            const vh = window.innerHeight;
            layers.forEach((el) => {
              const r = el.getBoundingClientRect();
              if (r.bottom < 0 || r.top > vh) return;
              const progress = (r.top + r.height / 2 - vh / 2) / vh; // -0.5..0.5
              el.style.transform = `translate3d(0, ${(-progress * 7).toFixed(2)}%, 0)`;
            });
            ticking = false;
          };
          const onScroll = () => {
            if (!ticking) {
              ticking = true;
              requestAnimationFrame(update);
            }
          };
          window.addEventListener("scroll", onScroll, { passive: true });
          window.addEventListener("resize", onScroll, { passive: true });
          update();
        }
      }
    </script>
  </body>
</html>
