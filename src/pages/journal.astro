---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Section from "../components/Section.astro";
import Button from "../components/Button.astro";
---

<BaseLayout
  title="Journal"
  description="Notes on construction project management, renovation, and design-forward building in Palm Springs and the Coachella Valley."
>
  <PageHeader
    eyebrow="Notes & perspective"
    title="Journal"
    lede="Thoughts on managing renovations well in a design-forward desert. Articles arrive in a later phase."
  />

  <Section tone="cream" reveal={true} width="narrow">
    <p class="eyebrow">Coming soon</p>
    <h2>The journal is being written.</h2>
    <p class="text-muted measure">
      This space will hold short, useful pieces for owners considering a
      renovation or build. The index and article layout will be added later.
    </p>
    <div class="stub-cta">
      <Button href="/contact" variant="primary">Schedule a Consultation</Button>
    </div>
  </Section>
</BaseLayout>

<style>
  h2 {
    margin-block: var(--space-3) var(--space-3);
  }
  .stub-cta {
    margin-top: var(--space-5);
  }
</style>
