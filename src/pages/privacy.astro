---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Section from "../components/Section.astro";

const updated = "June 2026";
---

<BaseLayout
  title="Privacy Policy"
  description="How Renovation Consulting Co. collects, uses, and protects the information you share with us."
  noindex={true}
>
  <PageHeader eyebrow="Information" title="Privacy Policy" />
  <Section tone="cream" width="narrow">
    <div class="legal">
      <p class="legal__updated text-muted">Last updated: {updated}</p>

      <p>
        Renovation Consulting Co. ("we," "us") respects your privacy. This policy
        explains what information we collect through this website and how we use
        it.
      </p>

      <h2>Information we collect</h2>
      <p>
        We collect the information you choose to provide — such as your name,
        email address, phone number, and project details — when you submit our
        consultation form or contact us directly. We may also collect basic,
        non-identifying analytics about how visitors use the site.
      </p>

      <h2>How we use your information</h2>
      <p>
        We use the information you provide solely to respond to your inquiry,
        schedule consultations, and communicate with you about your project. We
        do not sell your personal information.
      </p>

      <h2>Sharing</h2>
      <p>
        We share information only with service providers who help us operate the
        site or communicate with you, and only as needed to do so — or when
        required by law.
      </p>

      <h2>Your choices</h2>
      <p>
        You may request that we update or delete the information you've shared
        with us at any time by emailing
        <a href="mailto:info@rcc-cv.com">info@rcc-cv.com</a>.
      </p>

      <h2>Contact</h2>
      <p>
        Questions about this policy? Reach us at
        <a href="mailto:info@rcc-cv.com">info@rcc-cv.com</a> or 415-323-9320.
      </p>
    </div>
  </Section>
</BaseLayout>

<style>
  .legal :global(h2) {
    font-size: var(--fs-h3);
    font-weight: 400;
    margin-top: var(--space-5);
    margin-bottom: var(--space-2);
  }
  .legal :global(p) {
    margin-bottom: var(--space-3);
    line-height: 1.7;
  }
  .legal :global(a) {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .legal__updated {
    font-size: var(--fs-small);
    margin-bottom: var(--space-5);
  }
</style>
