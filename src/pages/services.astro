---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Section from "../components/Section.astro";
import Figure from "../components/Figure.astro";
import Marquee from "../components/Marquee.astro";
import Button from "../components/Button.astro";
import Stat from "../components/Stat.astro";
import CtaBand from "../components/CtaBand.astro";
import { images } from "../data/images";

const services = [
  {
    num: "01",
    title: "Pre-Construction & Planning",
    body: "The most valuable work happens before anything is built. We define scope, test feasibility, set a realistic budget, and make the early decisions that determine whether the rest of the project goes smoothly.",
    points: ["Goals, scope & feasibility", "Realistic preliminary budgeting", "Design & consultant coordination", "Permitting & approvals strategy"],
    image: images.interiorKitchen,
  },
  {
    num: "02",
    title: "Budget & Bid Management",
    body: "A bid is only useful if you can trust it. We level proposals so you're comparing like for like, read the fine print, and make sure the contract protects you before a signature ever lands on it.",
    points: ["Apples-to-apples bid leveling", "Line-item cost review", "Contract review & negotiation", "Contingency & allowance planning"],
    image: images.texture,
  },
  {
    num: "03",
    title: "Contractor & Trade Oversight",
    body: "Once construction begins, we are your eyes on site. We coordinate the builder and trades, verify that work matches the plans, and hold quality to the standard you're paying for — visit by visit.",
    points: ["Regular site visits & reporting", "Trade & subcontractor coordination", "Quality control & standards", "Issue resolution before it escalates"],
    image: images.construction,
  },
  {
    num: "04",
    title: "Schedule Management",
    body: "Time is money, and slippage is quiet until it isn't. We hold the schedule, track the critical path, and flag delays early — while they're still inexpensive to correct.",
    points: ["Master schedule development", "Critical-path tracking", "Early delay detection", "Milestone & dependency management"],
    image: images.lines,
  },
  {
    num: "05",
    title: "Change & Cost Control",
    body: "Change is inevitable; surprises are not. Every change order is reviewed, priced, and approved deliberately, so the budget reflects decisions you actually made.",
    points: ["Change-order review & pricing", "Pay-application verification", "Budget tracking & forecasting", "Transparent cost reporting"],
    image: images.interiorWarm,
  },
  {
    num: "06",
    title: "Quality & Close-Out",
    body: "A project isn't finished when the work stops — it's finished when it's truly complete. We manage punch lists, warranties, and final documentation for a clean, complete handover.",
    points: ["Punch-list management", "Final inspections & sign-off", "Warranty & documentation handover", "Post-project support"],
    image: images.exteriorDetail,
  },
];

const capabilities = [
  "Construction Management",
  "Owner's Representation",
  "Custom Homes",
  "Estate Renovations",
  "Budget Control",
  "Trade Coordination",
];
---

<BaseLayout
  title="Services"
  description="Full-scope construction management and owner's representation — pre-construction planning, budget and bid management, contractor oversight, scheduling, cost control, and close-out across Palm Springs and the Coachella Valley."
  image={images.construction.src}
>
  <PageHeader
    eyebrow="What we do"
    title="Construction management, on your side."
    lede="We manage the budget, the builders, and the timeline on your behalf — for the whole project, or for the stages where having an owner's advocate matters most."
    image={images.construction.src}
    imageAlt={images.construction.alt}
    fallback="ink"
  />

  <Marquee items={capabilities} tone="cream" />

  <!-- Service detail blocks (alternating imagery) -->
  <Section tone="cream">
    <div class="services">
      {
        services.map((s, i) => (
          <article class:list={["svc", { "svc--rev": i % 2 === 1 }]}>
            <div class="svc__media" data-reveal-clip>
              <Figure
                src={s.image.src}
                alt={s.image.alt}
                fallback={s.image.fallback}
                ratio="4 / 3"
                rounded={true}
                parallax={true}
                clip={false}
              />
            </div>
            <div class="svc__text" data-reveal-group>
              <span class="svc__num">{s.num}</span>
              <h2 class="svc__title">{s.title}</h2>
              <p class="svc__lede text-muted">{s.body}</p>
              <ul class="svc__points">
                {s.points.map((p) => <li>{p}</li>)}
              </ul>
            </div>
          </article>
        ))
      }
    </div>
  </Section>

  <!-- Who it's for -->
  <Section tone="ink">
    <div class="head" data-reveal>
      <p class="eyebrow eyebrow--rule">Who it's for</p>
      <h2 class="head__title">Built for owners who want it done right.</h2>
    </div>
    <div class="who" data-reveal-group>
      <div class="who__item">
        <span class="index-num">01</span>
        <h3>Homeowners & renovators</h3>
        <p>Taking on a significant build or renovation and wanting a professional who answers to you — not the contractor — at every decision.</p>
      </div>
      <div class="who__item">
        <span class="index-num">02</span>
        <h3>Second-home & remote owners</h3>
        <p>Managing a Coachella Valley property from afar and needing trusted eyes on site, steady reporting, and someone to make the calls in person.</p>
      </div>
      <div class="who__item">
        <span class="index-num">03</span>
        <h3>Design-forward projects</h3>
        <p>Honoring the desert's mid-century legacy, where craft and coordination both have to be exact for the result to feel effortless.</p>
      </div>
    </div>
  </Section>

  <!-- Stats -->
  <Section tone="blush">
    <div class="stats" data-reveal-group>
      <Stat figure="20+" label="Years of construction experience" />
      <Stat figure="End-to-end" label="From first drawing to final walkthrough" />
      <Stat figure="Owner-first" label="Representing your interests, always" />
    </div>
  </Section>

  <CtaBand
    eyebrow="Not sure how much support you need?"
    title="That's what the first conversation is for."
    text="We'll talk through your project and recommend the right level of involvement — no pressure, no obligation."
    image={images.interiorWarm.src}
    imageAlt={images.interiorWarm.alt}
  />
</BaseLayout>

<style>
  .services {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }
  .svc {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    align-items: center;
  }
  .svc__num {
    font-family: var(--font-display);
    font-size: 1rem;
    letter-spacing: 0.1em;
    color: var(--terracotta);
  }
  .svc__title {
    font-size: var(--fs-h2);
    font-weight: 300;
    margin-block: var(--space-2) var(--space-3);
  }
  .svc__lede {
    max-width: 52ch;
    margin-bottom: var(--space-4);
  }
  .svc__points {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0.7rem;
  }
  .svc__points li {
    position: relative;
    padding-left: 1.5rem;
    font-size: var(--fs-small);
  }
  .svc__points li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 7px;
    height: 7px;
    border: 1px solid var(--terracotta);
    transform: rotate(45deg);
  }
  @media (min-width: 860px) {
    .svc {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-7);
    }
    .svc--rev .svc__media {
      order: 2;
    }
    .svc__points {
      grid-template-columns: 1fr 1fr;
    }
  }

  .head {
    max-width: 44rem;
    margin-bottom: var(--space-6);
  }
  .head__title {
    margin-top: var(--space-3);
  }

  .who {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }
  .who__item h3 {
    font-size: var(--fs-h4);
    font-weight: 500;
    margin-block: var(--space-2);
  }
  .who__item p {
    color: rgba(251, 247, 242, 0.75);
    font-size: var(--fs-small);
  }
  @media (min-width: 800px) {
    .who {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-6);
    }
  }

  .stats {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }
  @media (min-width: 720px) {
    .stats {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
