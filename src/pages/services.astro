---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Section from "../components/Section.astro";
import Button from "../components/Button.astro";
---

<BaseLayout
  title="Services"
  description="Full-service construction project management and owner's representation — budget, contractors, and timeline managed end to end across Palm Springs and the Coachella Valley."
>
  <PageHeader
    eyebrow="What we do"
    title="Services"
    lede="Full-service project management and owner's representation. Detailed offerings arrive in Phase 1 — the structure and design system are in place."
  />

  <Section tone="cream" reveal={true} width="narrow">
    <p class="eyebrow">Coming soon</p>
    <h2>This page is on-brand and ready for content.</h2>
    <p class="text-muted measure">
      A clear breakdown of services — pre-construction planning, budget and bid
      management, contractor oversight, and project close-out — will be added
      next.
    </p>
    <div class="stub-cta">
      <Button href="/contact" variant="primary">Schedule a Consultation</Button>
    </div>
  </Section>
</BaseLayout>

<style>
  h2 {
    margin-block: var(--space-3) var(--space-3);
  }
  .stub-cta {
    margin-top: var(--space-5);
  }
</style>
