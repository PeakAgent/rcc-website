---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Section from "../components/Section.astro";
import Button from "../components/Button.astro";
import Stat from "../components/Stat.astro";

const services = [
  {
    num: "01",
    title: "Pre-Construction & Planning",
    body: "The most valuable work happens before anything is built. We help you define scope, test feasibility, set a realistic budget, and make the early decisions that determine whether the rest of the project goes smoothly.",
    points: [
      "Goals, scope, and feasibility review",
      "Realistic preliminary budgeting",
      "Design and consultant coordination",
      "Permitting and approvals strategy",
    ],
  },
  {
    num: "02",
    title: "Budget & Bid Management",
    body: "A bid is only useful if you can trust it. We level proposals so you're comparing like for like, read the fine print, and make sure the contract protects you before a signature ever lands on it.",
    points: [
      "Apples-to-apples bid leveling",
      "Line-item cost review",
      "Contract review and negotiation support",
      "Contingency and allowance planning",
    ],
  },
  {
    num: "03",
    title: "Contractor & Trade Oversight",
    body: "Once construction begins, we are your eyes on site. We coordinate the trades, verify that work matches the plans, and hold quality to the standard you're paying for — visit by visit.",
    points: [
      "Regular site visits and reporting",
      "Trade and subcontractor coordination",
      "Quality control and standards enforcement",
      "Issue resolution before it escalates",
    ],
  },
  {
    num: "04",
    title: "Schedule Management",
    body: "Time is money, and slippage is quiet until it isn't. We hold the schedule, track the critical path, and flag delays early — while they're still inexpensive to correct.",
    points: [
      "Master schedule development",
      "Critical-path tracking",
      "Early delay detection",
      "Milestone and dependency management",
    ],
  },
  {
    num: "05",
    title: "Change & Cost Control",
    body: "Change is inevitable; surprises are not. Every change order is reviewed, priced, and approved deliberately, so the budget reflects decisions you actually made.",
    points: [
      "Change-order review and pricing",
      "Pay-application verification",
      "Budget tracking and forecasting",
      "Transparent cost reporting",
    ],
  },
  {
    num: "06",
    title: "Quality & Close-Out",
    body: "A project isn't finished when the work stops — it's finished when it's truly complete. We manage punch lists, warranties, and final documentation so you're left with a clean, complete handover.",
    points: [
      "Punch-list management",
      "Final inspections and sign-off",
      "Warranty and documentation handover",
      "Post-project support",
    ],
  },
];
---

<BaseLayout
  title="Services"
  description="Full-service construction project management and owner's representation — pre-construction planning, budget and bid management, contractor oversight, scheduling, and close-out across Palm Springs and the Coachella Valley."
>
  <PageHeader
    eyebrow="What we do"
    title="Full-service project management, on your side."
    lede="Renovation Consulting Co. manages the budget, the contractors, and the timeline on your behalf — for the whole project, or for the stages where having an owner's advocate matters most."
  />

  <!-- Service detail blocks -->
  <Section tone="cream">
    <div class="services">
      {
        services.map((s) => (
          <article class="service" data-reveal>
            <div class="service__head">
              <span class="service__num">{s.num}</span>
              <h2 class="service__title">{s.title}</h2>
            </div>
            <div class="service__body">
              <p class="service__lede">{s.body}</p>
              <ul class="service__points">
                {s.points.map((p) => (
                  <li>{p}</li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }
    </div>
  </Section>

  <!-- Who it's for -->
  <Section tone="blush" reveal={true}>
    <div class="who">
      <div class="who__head">
        <p class="eyebrow">Who it's for</p>
        <h2>Built for owners who want it done right.</h2>
      </div>
      <div class="who__cols">
        <div>
          <h3>Homeowners &amp; renovators</h3>
          <p class="text-muted">
            Taking on a significant renovation or custom home and wanting a
            professional who answers to you — not the contractor — through every
            decision.
          </p>
        </div>
        <div>
          <h3>Second-home &amp; remote owners</h3>
          <p class="text-muted">
            Managing a Coachella Valley property from afar and needing trusted
            eyes on site, steady reporting, and someone to make the calls in
            person.
          </p>
        </div>
        <div>
          <h3>Design-forward projects</h3>
          <p class="text-muted">
            Honoring the desert's mid-century legacy, where craft and
            coordination both have to be exact for the result to feel effortless.
          </p>
        </div>
      </div>
    </div>
  </Section>

  <!-- Stats / reassurance -->
  <Section tone="cream" reveal={true}>
    <div class="svc-stats">
      <Stat figure="20+" label="Years of construction experience" />
      <Stat figure="End-to-end" label="From first drawing to final walkthrough" />
      <Stat figure="Owner-first" label="Representing your interests, always" />
    </div>
  </Section>

  <!-- CTA -->
  <Section tone="ink" reveal={true}>
    <div class="svc-cta">
      <p class="eyebrow">Start here</p>
      <h2>Not sure how much support you need?</h2>
      <p>
        That's exactly what the first conversation is for. We'll talk through
        your project and recommend the right level of involvement — no pressure,
        no obligation.
      </p>
      <Button href="/contact" variant="light">Schedule a Consultation</Button>
    </div>
  </Section>
</BaseLayout>

<style>
  .services {
    display: flex;
    flex-direction: column;
  }
  .service {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
    padding-block: var(--space-6);
    border-top: 1px solid var(--greige);
  }
  .service:first-child {
    padding-top: 0;
    border-top: 0;
  }
  .service__num {
    font-family: var(--font-display);
    font-size: 1rem;
    letter-spacing: 0.1em;
    color: var(--terracotta);
  }
  .service__title {
    font-size: var(--fs-h2);
    font-weight: 300;
    margin-top: var(--space-2);
  }
  .service__lede {
    color: var(--greige-deep);
    max-width: 56ch;
    margin-bottom: var(--space-4);
  }
  .service__points {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }
  .service__points li {
    position: relative;
    padding-left: 1.5rem;
    font-size: var(--fs-small);
  }
  .service__points li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 8px;
    height: 8px;
    border: 1px solid var(--terracotta);
    transform: rotate(45deg);
  }
  @media (min-width: 860px) {
    .service {
      grid-template-columns: 1fr 1.3fr;
      gap: var(--space-6);
    }
    .service__points {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* Who */
  .who__head {
    max-width: 40rem;
    margin-bottom: var(--space-6);
  }
  .who__head h2 {
    margin-top: var(--space-3);
  }
  .who__cols {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }
  .who__cols h3 {
    font-size: var(--fs-h4);
    font-weight: 500;
    margin-bottom: var(--space-2);
  }
  @media (min-width: 800px) {
    .who__cols {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-5);
    }
  }

  .svc-stats {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }
  @media (min-width: 720px) {
    .svc-stats {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* CTA */
  .svc-cta {
    max-width: 44rem;
  }
  .svc-cta h2 {
    margin-block: var(--space-3) var(--space-3);
  }
  .svc-cta p {
    color: rgba(251, 247, 242, 0.78);
    margin-bottom: var(--space-5);
    max-width: 50ch;
  }
</style>
