---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Section from "../components/Section.astro";
import { images } from "../data/images";

const projectTypes = [
  "Whole-home renovation",
  "Kitchen or bath renovation",
  "Custom new build",
  "Addition or remodel",
  "Owner's representation only",
  "Not sure yet",
];
---

<BaseLayout
  title="Schedule a Consultation"
  description="Schedule a consultation with Renovation Consulting Co. — construction project management and owner's representation in Palm Springs and the Coachella Valley. The first conversation is always free."
>
  <PageHeader
    eyebrow="Let's talk"
    title="Schedule a consultation."
    lede="Tell us a little about your project. We'll be in touch to set up a calm, no-obligation conversation about your goals, your budget, and how the work would be managed."
    image={images.pool.src}
    imageAlt={images.pool.alt}
    fallback="dusk"
  />

  <Section tone="cream">
    <div class="contact">
      <!-- Form -->
      <div class="contact__form-wrap" data-reveal>
        <form
          class="form"
          id="consult-form"
          action="https://formspree.io/f/your-form-id"
          method="POST"
          novalidate
        >
          <!--
            FORM ENDPOINT: replace the action above with your real Formspree
            (or equivalent) form ID to receive submissions by email. Until then,
            the form is progressively enhanced to open the visitor's mail client
            addressed to info@rcc-cv.com with their details prefilled.
          -->
          <div class="form__row">
            <div class="field">
              <label for="name">Name <span aria-hidden="true">*</span></label>
              <input type="text" id="name" name="name" required autocomplete="name" />
            </div>
            <div class="field">
              <label for="email">Email <span aria-hidden="true">*</span></label>
              <input type="email" id="email" name="email" required autocomplete="email" />
            </div>
          </div>

          <div class="form__row">
            <div class="field">
              <label for="phone">Phone</label>
              <input type="tel" id="phone" name="phone" autocomplete="tel" />
            </div>
            <div class="field">
              <label for="project-type">Project type</label>
              <select id="project-type" name="project-type">
                <option value="" selected>Select one…</option>
                {projectTypes.map((t) => <option value={t}>{t}</option>)}
              </select>
            </div>
          </div>

          <div class="field">
            <label for="location">Project location</label>
            <input
              type="text"
              id="location"
              name="location"
              placeholder="e.g. Palm Springs, CA"
              autocomplete="address-level2"
            />
          </div>

          <div class="field">
            <label for="message">
              Tell us about your project <span aria-hidden="true">*</span>
            </label>
            <textarea id="message" name="message" rows="6" required
              placeholder="What are you planning, and what's your timeline?"></textarea>
          </div>

          <div class="form__footer">
            <button type="submit" class="btn btn--primary form__submit">
              <span class="btn__label">Send &amp; schedule</span>
            </button>
            <p class="form__note text-muted">
              Prefer to talk now? Call
              <a href="tel:+14153239320">415-323-9320</a>.
            </p>
          </div>

          <p class="form__status" id="form-status" role="status" aria-live="polite"></p>
        </form>
      </div>

      <!-- Direct details -->
      <aside class="contact__details" data-reveal>
        <div class="detail">
          <h2 class="detail__heading">Direct</h2>
          <address class="detail__address">
            <a href="tel:+14153239320">415-323-9320</a>
            <a href="mailto:info@rcc-cv.com">info@rcc-cv.com</a>
          </address>
        </div>

        <div class="detail">
          <h2 class="detail__heading">Office</h2>
          <p class="detail__text">
            1276 N. Palm Canyon Dr, Suite 109-A<br />
            Palm Springs, CA 92264
          </p>
        </div>

        <div class="detail">
          <h2 class="detail__heading">Service area</h2>
          <p class="detail__text text-muted">
            Palm Springs, Rancho Mirage, Palm Desert, La Quinta, Indian Wells,
            and the wider Coachella Valley.
          </p>
        </div>

        <div class="detail">
          <h2 class="detail__heading">What happens next</h2>
          <p class="detail__text text-muted">
            We'll review your note and reach out to arrange a free, no-obligation
            consultation — usually within one business day.
          </p>
        </div>
      </aside>
    </div>
  </Section>
</BaseLayout>

<style>
  .contact {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
  @media (min-width: 880px) {
    .contact {
      grid-template-columns: 1.5fr 1fr;
      gap: var(--space-7);
    }
  }

  /* Form */
  .form {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .form__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
  }
  @media (min-width: 560px) {
    .form__row {
      grid-template-columns: 1fr 1fr;
    }
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .field label {
    font-size: var(--fs-small);
    font-weight: 600;
    color: var(--ink);
  }
  .field label span {
    color: var(--terracotta);
  }
  .field input,
  .field select,
  .field textarea {
    width: 100%;
    padding: 0.85rem 1rem;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--ink);
    background-color: var(--cream);
    border: 1px solid var(--greige);
    border-radius: var(--radius);
    transition: border-color 0.25s var(--ease), box-shadow 0.25s var(--ease);
  }
  .field textarea {
    resize: vertical;
  }
  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px rgba(177, 62, 39, 0.12);
  }
  .field input::placeholder,
  .field textarea::placeholder {
    color: var(--greige);
  }
  .field [aria-invalid="true"] {
    border-color: var(--terracotta-deep);
  }

  .form__footer {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3) var(--space-4);
    margin-top: var(--space-2);
  }
  .form__submit {
    cursor: pointer;
  }
  .form__note {
    font-size: var(--fs-small);
    margin: 0;
  }
  .form__status {
    margin: 0;
    font-size: var(--fs-small);
    font-weight: 600;
    min-height: 1.2em;
  }
  .form__status.is-success {
    color: var(--terracotta-deep);
  }
  .form__status.is-error {
    color: var(--terracotta-deep);
  }

  /* Details */
  .contact__details {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  .detail__heading {
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: 600;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--greige-deep);
    margin-bottom: var(--space-2);
  }
  .detail__address {
    font-style: normal;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 300;
  }
  .detail__text {
    line-height: 1.6;
  }
</style>

<script>
  // Progressive enhancement: validate, then (until a real form endpoint is
  // configured) compose a mailto to info@rcc-cv.com so the form is usable now.
  const form = document.querySelector<HTMLFormElement>("#consult-form");
  const status = document.querySelector<HTMLElement>("#form-status");

  const USES_REAL_ENDPOINT =
    !!form && !form.action.includes("your-form-id");

  const setStatus = (msg: string, kind: "success" | "error" | "") => {
    if (!status) return;
    status.textContent = msg;
    status.classList.remove("is-success", "is-error");
    if (kind) status.classList.add(`is-${kind}`);
  };

  form?.addEventListener("submit", (e) => {
    // Native validation first.
    if (!form.checkValidity()) {
      e.preventDefault();
      form.querySelectorAll<HTMLElement>(":invalid").forEach((el) =>
        el.setAttribute("aria-invalid", "true")
      );
      const firstInvalid = form.querySelector<HTMLElement>(":invalid");
      firstInvalid?.focus();
      setStatus("Please complete the required fields.", "error");
      return;
    }

    // If a real endpoint is set, let the POST proceed normally.
    if (USES_REAL_ENDPOINT) return;

    // Otherwise fall back to a prefilled email.
    e.preventDefault();
    const data = new FormData(form);
    const get = (k: string) => String(data.get(k) ?? "").trim();

    const body = [
      `Name: ${get("name")}`,
      `Email: ${get("email")}`,
      `Phone: ${get("phone") || "—"}`,
      `Project type: ${get("project-type") || "—"}`,
      `Location: ${get("location") || "—"}`,
      "",
      get("message"),
    ].join("\n");

    const href =
      "mailto:info@rcc-cv.com" +
      `?subject=${encodeURIComponent("Consultation request — " + get("name"))}` +
      `&body=${encodeURIComponent(body)}`;

    window.location.href = href;
    setStatus(
      "Opening your email app to send. If nothing happens, email info@rcc-cv.com directly.",
      "success"
    );
  });

  // Clear the invalid flag as the visitor corrects a field.
  form?.querySelectorAll("input, select, textarea").forEach((el) => {
    el.addEventListener("input", () => el.removeAttribute("aria-invalid"));
  });
</script>
