---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import Button from "../components/Button.astro";
---

<BaseLayout
  title="Page not found"
  description="The page you're looking for could not be found."
  noindex={true}
>
  <Section tone="cream">
    <div class="notfound">
      <p class="eyebrow">404</p>
      <h1>This page has moved on.</h1>
      <p class="text-muted measure">
        The page you're looking for isn't here. Let's get you back on track.
      </p>
      <div class="notfound__cta">
        <Button href="/" variant="outline">Return Home</Button>
        <Button href="/contact" variant="primary">Schedule a Consultation</Button>
      </div>
    </div>
  </Section>
</BaseLayout>

<style>
  .notfound {
    max-width: 40rem;
    padding-top: calc(var(--nav-h) + var(--space-4));
  }
  .notfound h1 {
    margin-block: var(--space-3) var(--space-3);
  }
  .notfound__cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-5);
  }
</style>
