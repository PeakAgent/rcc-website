---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Section from "../components/Section.astro";
import Button from "../components/Button.astro";
---

<BaseLayout
  title="Process"
  description="A clear, orderly approach to managing construction projects — from planning and budgeting through contractor oversight to a clean close-out."
>
  <PageHeader
    eyebrow="How it works"
    title="Process"
    lede="A calm, ordered method — as controlled as the service itself. The step-by-step breakdown arrives in Phase 1."
  />

  <Section tone="blush" reveal={true} width="narrow">
    <p class="eyebrow">Coming soon</p>
    <h2>A defined path, start to finish.</h2>
    <p class="text-muted measure">
      Planning, budgeting and bids, contractor management, and project
      close-out will be detailed here next.
    </p>
    <div class="stub-cta">
      <Button href="/contact" variant="primary">Schedule a Consultation</Button>
    </div>
  </Section>
</BaseLayout>

<style>
  h2 {
    margin-block: var(--space-3) var(--space-3);
  }
  .stub-cta {
    margin-top: var(--space-5);
  }
</style>
