---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Section from "../components/Section.astro";
import ImageSlot from "../components/ImageSlot.astro";
import Button from "../components/Button.astro";
import Stat from "../components/Stat.astro";
import Quote from "../components/Quote.astro";

const values = [
  {
    title: "Clarity over jargon",
    body: "You'll always understand where your project stands and what the next decision is. No mystery, no runaround.",
  },
  {
    title: "Your interests, first",
    body: "We represent you — not the contractor. Every recommendation is measured against your goals and your budget.",
  },
  {
    title: "Calm, methodical control",
    body: "Construction is chaotic by default. Our job is to make it orderly, so the process feels as considered as the result.",
  },
  {
    title: "Honesty, even when it's hard",
    body: "If something isn't right, you'll hear it early and plainly — while it's still inexpensive to fix.",
  },
];
---

<BaseLayout
  title="About"
  description="Daniel Hekkel — construction project manager and owner's representative with 20+ years of experience, bringing calm, methodical oversight to renovations and custom builds across Palm Springs and the Coachella Valley."
>
  <PageHeader
    eyebrow="Who we are"
    title="Twenty years of bringing order to construction."
    lede="Renovation Consulting Co. is led by Daniel Hekkel — a construction project manager and owner's representative who works for one person on every project: you."
  />

  <!-- Bio -->
  <Section tone="cream">
    <div class="bio">
      <div class="bio__media" data-reveal>
        <!-- REAL PHOTO SLOT — replace with Daniel Hekkel's actual portrait. -->
        <ImageSlot ratio="3 / 4" label="Daniel Hekkel" />
      </div>
      <div class="bio__text" data-reveal>
        <p class="eyebrow">Daniel Hekkel</p>
        <h2>An owner's advocate, not a contractor.</h2>
        <p>
          Over more than two decades in construction, Daniel has seen the same
          pattern again and again: projects rarely fail on craft. They fail on
          coordination, communication, and decisions made too late. The work is
          good — the management is missing.
        </p>
        <p>
          He founded Renovation Consulting Co. to supply exactly that missing
          piece. As an owner's representative, Daniel sits on the client's side
          of the table, managing budgets, contractors, and timelines so that
          building a home doesn't require becoming a construction manager.
        </p>
        <p>
          Based in Palm Springs, he works across the Coachella Valley — a
          design-forward, mid-century-modern community where craft and
          coordination both have to be precise for the result to feel
          effortless.
        </p>
      </div>
    </div>
  </Section>

  <!-- Quote -->
  <Section tone="blush" reveal={true}>
    <Quote cite="Daniel Hekkel" role="Founder, Renovation Consulting Co.">
      My measure of success is simple: the client got to enjoy their project
      instead of managing it.
    </Quote>
  </Section>

  <!-- Approach / values -->
  <Section tone="cream" reveal={true}>
    <div class="section-head">
      <p class="eyebrow">How we work</p>
      <h2>The principles behind every project.</h2>
    </div>
    <div class="values">
      {
        values.map((v) => (
          <div class="value-item">
            <h3>{v.title}</h3>
            <p class="text-muted">{v.body}</p>
          </div>
        ))
      }
    </div>
  </Section>

  <!-- Stats -->
  <Section tone="blush" reveal={true}>
    <div class="about-stats">
      <Stat figure="20+" label="Years managing construction projects" />
      <Stat figure="Coachella Valley" label="Palm Springs and the surrounding desert" />
      <Stat figure="Owner-first" label="Always representing the client's interests" />
    </div>
  </Section>

  <!-- Service area -->
  <Section tone="cream" reveal={true}>
    <div class="area">
      <div>
        <p class="eyebrow">Where we work</p>
        <h2>Palm Springs &amp; the Coachella Valley.</h2>
        <p class="text-muted measure">
          Renovation Consulting Co. serves clients throughout the desert
          communities — Palm Springs, Rancho Mirage, Palm Desert, La Quinta,
          Indian Wells, and the surrounding valley. If you're considering a
          project in the area, the first conversation is always free.
        </p>
        <div class="area__cta">
          <Button href="/contact" variant="primary">Schedule a Consultation</Button>
        </div>
      </div>
      <ul class="area__list">
        <li>Palm Springs</li>
        <li>Rancho Mirage</li>
        <li>Palm Desert</li>
        <li>La Quinta</li>
        <li>Indian Wells</li>
        <li>Cathedral City</li>
      </ul>
    </div>
  </Section>
</BaseLayout>

<style>
  .bio {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    align-items: start;
  }
  .bio__text h2 {
    margin-block: var(--space-3) var(--space-4);
  }
  @media (min-width: 860px) {
    .bio {
      grid-template-columns: 0.85fr 1.15fr;
      gap: var(--space-7);
    }
  }

  .section-head {
    max-width: 42rem;
    margin-bottom: var(--space-6);
  }
  .section-head h2 {
    margin-top: var(--space-3);
  }

  .values {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }
  .value-item h3 {
    font-size: var(--fs-h4);
    font-weight: 500;
    margin-bottom: var(--space-2);
    padding-top: var(--space-3);
    border-top: 1px solid var(--greige);
  }
  @media (min-width: 720px) {
    .values {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-5) var(--space-6);
    }
  }

  .about-stats {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }
  @media (min-width: 720px) {
    .about-stats {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .area {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    align-items: center;
  }
  .area h2 {
    margin-block: var(--space-3) var(--space-3);
  }
  .area__cta {
    margin-top: var(--space-5);
  }
  .area__list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }
  .area__list li {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 300;
    padding-block: var(--space-2);
    border-top: 1px solid var(--greige);
  }
  @media (min-width: 860px) {
    .area {
      grid-template-columns: 1.3fr 0.7fr;
      gap: var(--space-7);
    }
  }
</style>
