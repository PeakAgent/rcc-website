---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Section from "../components/Section.astro";
import Figure from "../components/Figure.astro";
import ImageSlot from "../components/ImageSlot.astro";
import Button from "../components/Button.astro";
import Stat from "../components/Stat.astro";
import Quote from "../components/Quote.astro";
import CtaBand from "../components/CtaBand.astro";
import { images } from "../data/images";

const values = [
  { num: "01", title: "Clarity over jargon", body: "You'll always understand where the project stands and what the next decision is. No mystery, no runaround." },
  { num: "02", title: "Your interests, first", body: "We represent you — not the contractor. Every recommendation is measured against your goals and your budget." },
  { num: "03", title: "Calm, methodical control", body: "Construction is chaotic by default. Our job is to make it orderly, so the process feels as considered as the result." },
  { num: "04", title: "Honesty, even when it's hard", body: "If something isn't right, you'll hear it early and plainly — while it's still inexpensive to fix." },
];

const areas = ["Palm Springs", "Rancho Mirage", "Palm Desert", "La Quinta", "Indian Wells", "Cathedral City"];
---

<BaseLayout
  title="About"
  description="Daniel Hekkel — construction manager and owner's representative with 20+ years of experience, bringing calm, methodical oversight to high-end homes across Palm Springs and the Coachella Valley."
  image={images.desert.src}
>
  <PageHeader
    eyebrow="Who we are"
    title="Twenty years of bringing order to construction."
    lede="Renovation Consulting Co. is led by Daniel Hekkel — a construction manager and owner's representative who works for one person on every project: you."
    image={images.desert.src}
    imageAlt={images.desert.alt}
    fallback="clay"
  />

  <!-- Bio -->
  <Section tone="cream">
    <div class="bio">
      <div class="bio__media" data-reveal-clip>
        <!-- REAL PHOTO SLOT — replace with Daniel Hekkel's actual portrait. -->
        <ImageSlot ratio="3 / 4" label="Daniel Hekkel" />
      </div>
      <div class="bio__text" data-reveal-group>
        <p class="eyebrow eyebrow--rule">Daniel Hekkel</p>
        <h2>A construction manager who works for you.</h2>
        <p>
          Over more than two decades in construction, Daniel has seen the same
          pattern again and again: projects rarely fail on craft. They fail on
          coordination, communication, and decisions made too late. The work is
          good — the management is missing.
        </p>
        <p>
          He founded Renovation Consulting Co. to supply exactly that missing
          piece. As a construction manager and owner's representative, Daniel
          sits on the client's side of the table, running budgets, builders, and
          timelines so that creating a home doesn't require becoming a
          construction manager yourself.
        </p>
        <p>
          Based in Palm Springs, he works across the Coachella Valley — a
          design-forward, mid-century-modern community where craft and
          coordination both have to be precise for the result to feel
          effortless.
        </p>
      </div>
    </div>
  </Section>

  <!-- Quote band -->
  <Section tone="ink">
    <Quote cite="Daniel Hekkel" role="Founder, Renovation Consulting Co.">
      My measure of success is simple: the client got to enjoy their project
      instead of managing it.
    </Quote>
  </Section>

  <!-- Values -->
  <Section tone="cream">
    <div class="head" data-reveal>
      <p class="eyebrow eyebrow--rule">How we work</p>
      <h2 class="head__title">The principles behind every project.</h2>
    </div>
    <div class="values" data-reveal-group>
      {
        values.map((v) => (
          <div class="value-item">
            <span class="index-num">{v.num}</span>
            <h3>{v.title}</h3>
            <p class="text-muted">{v.body}</p>
          </div>
        ))
      }
    </div>
  </Section>

  <!-- Texture band image -->
  <Section tone="cream" container={false}>
    <div class="band" data-reveal-clip>
      <Figure
        src={images.interiorWarm.src}
        alt={images.interiorWarm.alt}
        fallback="sand"
        ratio="21 / 9"
        parallax={true}
        clip={false}
      />
    </div>
  </Section>

  <!-- Stats -->
  <Section tone="blush">
    <div class="stats" data-reveal-group>
      <Stat figure="20+" label="Years managing construction" />
      <Stat figure="Coachella Valley" label="Palm Springs and the surrounding desert" />
      <Stat figure="Owner-first" label="Always representing the client's interests" />
    </div>
  </Section>

  <!-- Service area -->
  <Section tone="cream">
    <div class="area">
      <div class="area__text" data-reveal-group>
        <p class="eyebrow eyebrow--rule">Where we work</p>
        <h2>Palm Springs & the Coachella Valley.</h2>
        <p class="text-muted measure">
          Renovation Consulting Co. serves clients throughout the desert
          communities. If you're considering a project in the area, the first
          conversation is always free.
        </p>
        <Button href="/contact" variant="primary">Schedule a Consultation</Button>
      </div>
      <ul class="area__list" data-reveal-group>
        {areas.map((a) => <li>{a}</li>)}
      </ul>
    </div>
  </Section>

  <CtaBand
    title="Let's build something considered."
    text="Tell Daniel about your project and what you're hoping to achieve."
    image={images.exteriorDetail.src}
    imageAlt={images.exteriorDetail.alt}
  />
</BaseLayout>

<style>
  .bio {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    align-items: start;
  }
  .bio__text h2 {
    margin-block: var(--space-3) var(--space-4);
  }
  @media (min-width: 860px) {
    .bio {
      grid-template-columns: 0.85fr 1.15fr;
      gap: var(--space-7);
    }
    .bio__media {
      position: sticky;
      top: calc(var(--nav-h) + 2rem);
    }
  }

  .head {
    max-width: 44rem;
    margin-bottom: var(--space-6);
  }
  .head__title {
    margin-top: var(--space-3);
  }

  .values {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5) var(--space-6);
  }
  .value-item h3 {
    font-size: var(--fs-h4);
    font-weight: 500;
    margin-block: var(--space-2);
    padding-top: var(--space-3);
    border-top: 1px solid var(--hairline);
  }
  @media (min-width: 720px) {
    .values {
      grid-template-columns: 1fr 1fr;
    }
  }

  .band {
    padding-inline: var(--gutter);
  }
  .band :global(.figure) {
    max-width: var(--container-max);
    margin-inline: auto;
  }

  .stats {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }
  @media (min-width: 720px) {
    .stats {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .area {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    align-items: center;
  }
  .area h2 {
    margin-block: var(--space-3) var(--space-3);
  }
  .area__text :global(.btn) {
    margin-top: var(--space-5);
  }
  .area__list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
  }
  .area__list li {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 300;
    padding-block: var(--space-2);
    border-top: 1px solid var(--hairline);
  }
  @media (min-width: 860px) {
    .area {
      grid-template-columns: 1.3fr 0.7fr;
      gap: var(--space-7);
    }
  }
</style>
