---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Section from "../components/Section.astro";
import ImageSlot from "../components/ImageSlot.astro";
import Button from "../components/Button.astro";
---

<BaseLayout
  title="About"
  description="Daniel Hekkel — construction project manager and owner's representative with 20+ years of experience, serving Palm Springs and the Coachella Valley."
>
  <PageHeader
    eyebrow="Who we are"
    title="About"
    lede="Daniel Hekkel — 20+ years managing budgets, contractors, and timelines on behalf of owners. Full story arrives in Phase 1."
  />

  <Section tone="cream" reveal={true}>
    <div class="about">
      <div class="about__text">
        <p class="eyebrow">Coming soon</p>
        <h2>An owner's advocate, not a contractor.</h2>
        <p class="text-muted measure">
          The full biography, philosophy, and experience will be added next.
          For now, this page proves the layout and design system.
        </p>
        <div class="stub-cta">
          <Button href="/contact" variant="primary">Schedule a Consultation</Button>
        </div>
      </div>
      <div class="about__media">
        <!-- REAL PHOTO SLOT — replace with Daniel's actual portrait / project photography. -->
        <ImageSlot ratio="3 / 4" label="Portrait" />
      </div>
    </div>
  </Section>
</BaseLayout>

<style>
  .about {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    align-items: center;
  }
  .about__text h2 {
    margin-block: var(--space-3) var(--space-3);
  }
  .stub-cta {
    margin-top: var(--space-5);
  }
  @media (min-width: 860px) {
    .about {
      grid-template-columns: 1.4fr 1fr;
      gap: var(--space-7);
    }
  }
</style>
