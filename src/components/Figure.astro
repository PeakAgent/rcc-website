---
/**
 * Figure — atmosphere image with a branded gradient fallback that is ALWAYS
 * present beneath the photo. If the image loads, it fades in over the gradient;
 * if it fails (or is slow), the gradient stands alone and still looks designed.
 * Handled by the global image script in BaseLayout (load/error listeners).
 *
 * Use for ATMOSPHERE only — never as a captioned "our project" photo.
 */
import type { Fallback } from "../data/images";

interface Props {
  src: string;
  alt: string;
  ratio?: string;
  fallback?: Fallback;
  eager?: boolean;
  sizes?: string;
  parallax?: boolean;
  clip?: boolean;
  class?: string;
  rounded?: boolean;
}

const {
  src,
  alt,
  ratio = "4 / 3",
  fallback = "sand",
  eager = false,
  sizes = "(max-width: 800px) 100vw, 50vw",
  parallax = false,
  clip = true,
  class: className = "",
  rounded = false,
} = Astro.props;
---

<figure
  class:list={["figure", { "figure--rounded": rounded }, className]}
  data-reveal-clip={clip ? "" : undefined}
  style={`--ar: ${ratio};`}
>
  <div class:list={["figure__frame", `fb-${fallback}`]}>
    <img
      class="figure__img"
      data-img
      data-parallax={parallax ? "" : undefined}
      src={src}
      alt={alt}
      loading={eager ? "eager" : "lazy"}
      fetchpriority={eager ? "high" : "auto"}
      decoding="async"
      sizes={sizes}
    />
  </div>
</figure>

<style>
  .figure {
    margin: 0;
    width: 100%;
  }
  .figure--rounded .figure__frame {
    border-radius: var(--radius-lg);
  }
  .figure__frame {
    position: relative;
    width: 100%;
    aspect-ratio: var(--ar);
    overflow: hidden;
    background-color: var(--sand);
  }
  .figure__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transform: scale(1.04);
    transition: opacity 1s var(--ease-out), transform 6s var(--ease-out);
  }
  .figure__img.is-loaded {
    opacity: 1;
    transform: scale(1);
  }
  .figure__img.is-failed {
    display: none;
  }
  .figure__img[data-parallax] {
    height: 118%;
    inset: -9% 0;
    will-change: transform;
    transform: none;
    transition: opacity 1s var(--ease-out);
  }
  .figure__img[data-parallax].is-loaded {
    transform: none;
  }

  /* Branded gradient fallbacks (also a tasteful base beneath every photo) */
  .fb-dusk {
    background: linear-gradient(150deg, #3a201a 0%, #6e2f20 48%, #b13e27 100%);
  }
  .fb-sand {
    background: linear-gradient(150deg, #efe2d6 0%, #e0cdbd 100%);
  }
  .fb-clay {
    background: linear-gradient(150deg, #c8745a 0%, #8f3220 100%);
  }
  .fb-ink {
    background: linear-gradient(150deg, #3a322b 0%, #241e1a 100%);
  }
  .fb-blush {
    background: linear-gradient(150deg, #f4e3dc 0%, #e4cabf 100%);
  }

  @media (prefers-reduced-motion: reduce) {
    .figure__img {
      transition: opacity 0.4s ease;
      transform: none;
    }
    .figure__img.is-loaded {
      transform: none;
    }
  }

  /* No-JS: never leave the photo hidden */
  :global(html:not(.js)) .figure__img {
    opacity: 1;
    transform: none;
  }
</style>
