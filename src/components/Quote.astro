---
/**
 * Quote — a calm pull-quote / testimonial block.
 * NOTE: Phase content uses illustrative placeholder attribution until real
 * client testimonials are collected.
 */
interface Props {
  cite?: string;
  role?: string;
}
const { cite, role } = Astro.props;
---

<figure class="quote">
  <blockquote class="quote__text">
    <slot />
  </blockquote>
  {
    cite && (
      <figcaption class="quote__cite">
        <span class="quote__name">{cite}</span>
        {role && <span class="quote__role">{role}</span>}
      </figcaption>
    )
  }
</figure>

<style>
  .quote {
    margin: 0;
    max-width: 48rem;
  }
  .quote__text {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .quote__text::before {
    content: "“";
    color: var(--terracotta);
  }
  .quote__text::after {
    content: "”";
    color: var(--terracotta);
  }
  .quote__cite {
    margin-top: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .quote__name {
    font-size: var(--fs-small);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink);
  }
  .quote__role {
    font-size: var(--fs-small);
    color: var(--greige-deep);
  }
</style>
