---
/**
 * Button — renders an <a> when `href` is given, otherwise a <button>.
 * Variants:
 *   primary  — solid terracotta (main CTA; use sparingly)
 *   outline  — quiet bordered button on light grounds
 *   ghost    — minimal text + underline reveal (inline calls to action)
 *   light    — for use on the dark ink ground
 */
interface Props {
  href?: string;
  variant?: "primary" | "outline" | "ghost" | "light" | "hero-ghost";
  type?: "button" | "submit" | "reset";
  class?: string;
  [key: string]: unknown;
}

const {
  href,
  variant = "primary",
  type = "button",
  class: className = "",
  ...rest
} = Astro.props;

const Tag = href ? "a" : "button";
---

<Tag
  href={href}
  type={href ? undefined : type}
  class:list={["btn", `btn--${variant}`, className]}
  {...rest}
>
  <span class="btn__label"><slot /></span>
</Tag>

<style>
  .btn {
    --btn-pad-y: 1rem;
    --btn-pad-x: 1.8rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: var(--btn-pad-y) var(--btn-pad-x);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    line-height: 1;
    text-align: center;
    cursor: pointer;
    border: 1px solid transparent;
    border-radius: var(--radius);
    transition: background-color 0.3s var(--ease), color 0.3s var(--ease),
      border-color 0.3s var(--ease), transform 0.3s var(--ease),
      box-shadow 0.3s var(--ease);
  }

  /* hero-ghost — transparent w/ cream outline for dark hero grounds */
  .btn--hero-ghost {
    background-color: rgba(251, 247, 242, 0.06);
    color: var(--cream);
    border-color: rgba(251, 247, 242, 0.5);
    backdrop-filter: blur(4px);
  }
  .btn--hero-ghost:hover {
    background-color: var(--cream);
    color: var(--ink);
    border-color: var(--cream);
  }

  .btn:hover {
    transform: translateY(-1px);
  }

  .btn:active {
    transform: translateY(0);
  }

  /* primary — solid terracotta */
  .btn--primary {
    background-color: var(--terracotta);
    color: var(--cream);
    border-color: var(--terracotta);
  }
  .btn--primary:hover {
    background-color: var(--terracotta-deep);
    border-color: var(--terracotta-deep);
    color: var(--cream);
  }

  /* outline — quiet bordered on light grounds */
  .btn--outline {
    background-color: transparent;
    color: var(--ink);
    border-color: var(--greige);
  }
  .btn--outline:hover {
    border-color: var(--ink);
    color: var(--ink);
  }

  /* light — for the dark ink ground */
  .btn--light {
    background-color: var(--cream);
    color: var(--ink);
    border-color: var(--cream);
  }
  .btn--light:hover {
    background-color: transparent;
    color: var(--cream);
    border-color: var(--cream);
  }

  /* ghost — minimal inline CTA with an underline reveal */
  .btn--ghost {
    background-color: transparent;
    color: var(--terracotta);
    padding-inline: 0;
    border: 0;
  }
  .btn--ghost .btn__label {
    position: relative;
  }
  .btn--ghost .btn__label::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -3px;
    width: 100%;
    height: 1px;
    background-color: currentColor;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s var(--ease);
  }
  .btn--ghost:hover {
    color: var(--terracotta-deep);
    transform: none;
  }
  .btn--ghost:hover .btn__label::after {
    transform: scaleX(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .btn,
    .btn--ghost .btn__label::after {
      transition: none;
    }
    .btn:hover {
      transform: none;
    }
  }
</style>
