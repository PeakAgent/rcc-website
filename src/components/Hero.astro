---
import Container from "./Container.astro";
import Button from "./Button.astro";

/**
 * Hero shell — full-bleed, near full-viewport atmosphere with a warm gradient
 * overlay for legibility.
 *
 * SWAP NOTE: the media layer (`.hero__media`) is structured so the <img> can be
 * replaced by a <video> (autoplay muted loop playsinline) with zero layout
 * change. Keep the same wrapper + overlay; only the inner element changes.
 *
 * The background here is an ATMOSPHERE image — never presented as a real
 * Renovation Consulting Co. project.
 */
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  ctaLabel?: string;
  ctaHref?: string;
  image?: string;
  imageAlt?: string;
}

const {
  eyebrow,
  title,
  subtitle,
  ctaLabel = "Schedule a Consultation",
  ctaHref = "/contact",
  image = "/images/atmosphere/hero-atmosphere.svg",
  imageAlt = "Warm, minimal desert-modern interior — atmosphere",
} = Astro.props;
---

<section class="hero">
  <div class="hero__media">
    <!-- Swap this <img> for a <video> later; wrapper + overlay stay identical. -->
    <img class="hero__img" src={image} alt={imageAlt} fetchpriority="high" />
    <div class="hero__overlay" aria-hidden="true"></div>
  </div>

  <div class="hero__content">
    <Container>
      <div class="hero__inner">
        {eyebrow && <p class="eyebrow hero__eyebrow">{eyebrow}</p>}
        <h1 class="hero__title">{title}</h1>
        {subtitle && <p class="hero__subtitle">{subtitle}</p>}
        <div class="hero__actions">
          <Button href={ctaHref} variant="primary">{ctaLabel}</Button>
        </div>
      </div>
    </Container>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 92svh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background-color: var(--blush);
  }

  .hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    /* very slow ken-burns drift */
    animation: hero-zoom 26s ease-out forwards;
  }

  /* Warm gradient: ink fading to transparent for text legibility */
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
        to top,
        rgba(36, 30, 26, 0.72) 0%,
        rgba(36, 30, 26, 0.34) 38%,
        rgba(36, 30, 26, 0.06) 70%,
        rgba(36, 30, 26, 0.18) 100%
      );
  }

  .hero__content {
    position: relative;
    z-index: 1;
    width: 100%;
    padding-bottom: clamp(3rem, 8vh, 7rem);
    padding-top: calc(var(--nav-h) + var(--space-4));
  }

  .hero__inner {
    max-width: 56rem;
  }

  .hero__eyebrow {
    color: var(--blush);
    margin-bottom: var(--space-3);
  }

  .hero__title {
    color: var(--cream);
    font-size: var(--fs-hero);
    font-weight: 300;
    line-height: 1.02;
    letter-spacing: -0.025em;
  }

  .hero__subtitle {
    color: rgba(251, 247, 242, 0.86);
    font-size: clamp(1.125rem, 1.8vw, 1.4rem);
    line-height: 1.5;
    max-width: 44rem;
    margin-top: var(--space-4);
  }

  .hero__actions {
    margin-top: var(--space-5);
  }

  @keyframes hero-zoom {
    from {
      transform: scale(1.06);
    }
    to {
      transform: scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__img {
      animation: none;
    }
  }
</style>
